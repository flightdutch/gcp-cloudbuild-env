# ==============================================================================
# CONFIGURATION project env
# (Check/Change these values before running the scripts!)
# ==============================================================================

# GCP: project info
export PROJECT_ID="bf-lyser"
export PROJECT_NUMBER="102430436"
export REGION="europe-west3"

export GITHUB_REPO="flightdutch/gcp-cloudbuild-env"


# GCP: Internal system (WIF) variables for IaC-terraform deploy
#export SA_NAME="iac-deployer"
export WIF_SA_NAME="iac-deployer"
#export POOL_NAME="github-pool"
export WIF_POOL_NAME="github-pool"              # WIF pool name
#export PROVIDER_NAME="github-provider"
export WIF_PROVIDER_NAME="github-provider"      # WIF provider name

# GCP: terraform tfstate-bucket configuration
export TFSTATE_BUCKET_NAME="${PROJECT_ID}-tfstate"
export TFSTATE_RETENTION_VERSIONS="10"

LOGS_BUCKET_NAME="${PROJECT_ID}-raw-logs"

# GCP pub/sub configuration
#TOPIC_NAME="${PROJECT_ID}-log-events"
PUBSUB_TOPIC_NAME="${PROJECT_ID}-log-events"
#SA_NAME="${PROJECT_ID}-fn-sa"
PUBSUB_SA_NAME="${PROJECT_ID}-fn-sa"

SCHEDULER_NAME="${GCP_PROJECT}-report-cron"


